  "paper_metadata": {
    "arxiv_id": "2204.14198",
    "title": "Flamingo: a Visual Language Model for Few-Shot Learning",
    "authors": [
      "Jean-Baptiste Alayrac",
      "Jeff Donahue",
      "Pauline Luc",
      "Antoine Miech",
      "Iain Barr",
