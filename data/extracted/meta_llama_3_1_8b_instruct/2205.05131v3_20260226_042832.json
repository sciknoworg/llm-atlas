  "paper_metadata": {
    "arxiv_id": "2205.05131",
    "title": "UL2: Unifying Language Learning Paradigms",
    "authors": [
      "Yi Tay",
      "Mostafa Dehghani",
      "Vinh Q. Tran",
      "Xavier Garcia",
      "Jason Wei",
      "Xuezhi Wang",
      "Hyung Won Chung",
      "Siamak Shakeri",
