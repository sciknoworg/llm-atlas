  "paper_metadata": {
    "arxiv_id": "2203.02155",
    "title": "Training language models to follow instructions with human feedback",
    "authors": [
      "Long Ouyang",
      "Jeff Wu",
      "Xu Jiang",
      "Diogo Almeida",
      "Carroll L. Wainwright",
      "Pamela Mishkin",
