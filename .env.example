# ORKG API Configuration
# Create an account at https://orkg.org/ or https://sandbox.orkg.org/
ORKG_EMAIL=your.email@example.com
ORKG_PASSWORD=your_password_here

# ORKG Host Configuration
# Options: sandbox, incubating, production
# Use 'sandbox' for testing, 'production' for final thesis work
ORKG_HOST=sandbox

# KISSKI Chat AI API (SAIA Platform - for extraction)
# This API key is provided by your professor for thesis work
# DO NOT share this key with others
# API has rate limits: 1000/min, 10000/hour, 50000/day
# Client-side rate limiting is implemented (2 seconds between requests)
KISSKI_API_KEY=your_kisski_api_key_here
KISSKI_BASE_URL=https://chat-ai.academiccloud.de/v1

# Note for Grete HPC Users:
# When running on Grete cluster, you don't need KISSKI_API_KEY
# The extraction uses local GPU-based transformers instead of API calls
